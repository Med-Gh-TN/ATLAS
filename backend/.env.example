# ==========================================
# SECURITY
# ==========================================
# Generate a secure string using: openssl rand -hex 32
# DO NOT commit real secrets to version control.
SECRET_KEY=your_secure_generated_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ENVIRONMENT=development

# ==========================================
# DATABASE (Local Docker Setup)
# ==========================================
# Note: In Railway.app, this is automatically overridden by the natively injected DATABASE_URL.
POSTGRES_SERVER=localhost:5433
POSTGRES_USER=atlas_user
POSTGRES_PASSWORD=atlas_password
POSTGRES_DB=atlas_db

# ==========================================
# REDIS & CELERY
# ==========================================
# Note: In Railway.app, this is automatically overridden by the natively injected REDIS_URL.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1
QDRANT_URL=http://localhost:6333

# ==========================================
# MINIO (S3 Compatible Storage)
# ==========================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_password
MINIO_BUCKET_NAME=atlas-documents
MINIO_SECURE=False
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_ORIGIN_ROOT=https://atlas.tn
FRONTEND_ORIGIN_WWW=https://www.atlas.tn

# ==========================================
# EMAIL / SMTP (e.g., Gmail)
# ==========================================
# Use a dedicated testing email or app password.
# NEVER commit your personal email or real app password.
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_USER=your_dev_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAILS_FROM_EMAIL=your_dev_email@gmail.com
EMAILS_FROM_NAME="ATLAS Platform (Local/Dev)"

# Optional AI providers
OPENAI_API_KEY=
COHERE_API_KEY=
SENDGRID_API_KEY=
SENTRY_DSN=
