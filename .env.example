# ==========================================
# OMNI-ARCHITECT: ENVIRONMENT CONTRACT v6.2
# Multi-Key Task-Routed Architecture
# CPU-Realigned for i5-12500H (6P + 8E hybrid)
# ==========================================
# !! SECURITY WARNING !!
# Never commit this file with real credentials.
# Use Docker secrets, HashiCorp Vault, or AWS Secrets Manager in production.
# ==========================================
# ARCHITECTURE OVERVIEW
# ==========================================
# 4 dedicated API keys — one per pipeline stage.
# This distributes RPD/RPM quotas across independent Google AI Studio projects,
# so a burst in one stage (e.g., ingestion) never blocks another (e.g., queries).
# Per-key free-tier hard limits (Google AI Studio):
# gemini-3.1-flash-lite-preview: RPM=15, TPM=250K, RPD=500
# gemma-4-31b-it: RPM=15, TPM=∞, RPD=1500
# gemma-4-26b-a4b-it: RPM=15, TPM=∞, RPD=1500
# gemma-3-27b-it: RPM=30, TPM=15K, RPD=14400
# gemma-3-12b-it: RPM=30, TPM=15K, RPD=14400
# FALLBACK CHAIN PER TASK (defined in model_registry.py):
# INGEST_VISION: gemini-3.1-flash-lite-preview -> gemma-4-31b-it -> [Groq]
# INGEST_GRAPH: gemini-3.1-flash-lite-preview -> gemma-4-31b-it -> gemma-3-27b-it -> [Groq]
# QUERY_ROUTER: gemini-3.1-flash-lite-preview -> gemma-4-26b-a4b-it -> gemma-3-12b-it -> [Groq]
# QUERY_SYNTHESIS: gemini-3.1-flash-lite-preview -> gemma-4-31b-it -> gemma-3-27b-it -> [Groq]
# CIRCUIT BREAKER (Redis-backed):
# - RPM/TPM 429 with short retry_after -> wait and retry same model
# - RPD 429 (daily exhausted) -> OPEN CB for this task+model (24h cooldown)
# - 503 SERVICE_UNAVAILABLE -> OPEN CB (5 min cooldown)
# - Other errors -> record failure, failover immediately
# ==========================================

# ── 1. AI INFERENCE & ROUTING LAYER ──────────────────────────────────────────
# Each key maps to a dedicated Google AI Studio project.
# Key rotation: replace values here; no code changes required.

# INGEST_VISION: VLM image analysis + VLM OCR during document ingestion.
API_KEY_INGEST_VISION=your_google_ai_studio_key_here

# INGEST_GRAPH: Entity/relation KG extraction + content type classification.
API_KEY_INGEST_GRAPH=your_google_ai_studio_key_here

# QUERY_ROUTER: Fast query classification + query expansion.
API_KEY_QUERY_ROUTER=your_google_ai_studio_key_here

# QUERY_SYNTHESIS: Final answer synthesis from retrieved context.
API_KEY_QUERY_SYNTHESIS=your_google_ai_studio_key_here

# Primary model — used as first attempt for ALL tasks.
# Override per-task in model_registry.py TASK_PRIMARY_MODEL if needed.
GEMINI_MODEL_NAME=gemini-3.1-flash-lite-preview

# ── TIER-LAST AI PROVIDER (Groq — text-only emergency fallback)
# Groq is the final safety net when ALL Gemini/Gemma models in a task's
# fallback chain are unavailable. Vision data is stripped before sending.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_NAME=llama-3.3-70b-versatile


# ── 2. TOKENS, QUOTAS & CIRCUIT BREAKERS ─────────────────────────────────────

# ── RATE LIMIT CONFIGURATION
# These are SAFETY MARGINS applied on top of the model registry hard limits.
# The registry computes: safe_rpm = model_rpm * GEMINI_RPM_SAFETY_FACTOR
# Default 0.70 = 30% safety margin (conservative for free tier).
GEMINI_RPM_SAFETY_FACTOR=0.70

# RPD soft-limit awareness: WARNING is logged at this percentage of daily budget.
# Not a hard stop — the CB handles actual exhaustion via API error response.
GEMINI_RPD_SOFT_LIMIT_PCT=80

# ── CIRCUIT BREAKER CONFIGURATION
# CB_RPM_COOLDOWN_SECONDS: Wait time after an RPM/TPM 429 before a retry
# on the same model. If the API provides a retry_after value, that takes precedence.
CB_RPM_COOLDOWN_SECONDS=35

# CB_RPD_COOLDOWN_SECONDS: Cooldown after a daily quota (RPD) exhaustion.
# Default: 86400 (24 hours). The CB will be OPEN until this expires.
CB_RPD_COOLDOWN_SECONDS=86400

# CB_SERVICE_COOLDOWN_SECONDS: Cooldown after a 503 Service Unavailable.
CB_SERVICE_COOLDOWN_SECONDS=300

# CB_FAILURE_THRESHOLD: Number of consecutive failures before a model is
# tripped OPEN by the circuit breaker (for non-quota errors).
CB_FAILURE_THRESHOLD=2

# ── TOKEN BUDGETS
# Synthesis / Classification budget (short outputs):
GEMINI_MAX_OUTPUT_TOKENS=512

# KG Extraction budget (entity/relation JSON — can be large):
GEMINI_MAX_EXTRACTION_TOKENS=4096

# Multi-modal Asset Token limits
GEMINI_MAX_ASSET_TOKENS=8192

# Concurrency: MUST stay at 1 per task key to prevent RPM burst.
GEMINI_MAX_ASYNC_CALLS=1


# ── 3. ADVANCED RAG & SOTA PIPELINE ──────────────────────────────────────────

# Enterprise Feature Flags
ENTERPRISE_STORAGE_ENABLED=true
QDRANT_STRICT_ISOLATION=true

# SOTA RAG Engine Flags
HYDE_ENABLED=true
SEMANTIC_CACHE_ENABLED=true
QUERY_DECOMP_ENABLED=true
RERANKER_ENABLED=true
MATH_LATEX_NORMALIZE=true

# Reranker Model Specifications
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=5

# RAG Chunking Parameters
# gemma-3 models have TPM=15K, which limits to ~10 RPM at 1500 tokens/call.
# CHUNK_TOKEN_SIZE=1500 is safe for ALL models in the fallback chain.
CHUNK_TOKEN_SIZE=1500
CHUNK_OVERLAP=200
MAX_PAGES_PER_SLICE=5


# ── 4. EMBEDDING & CPU PIPELINE ARCHITECTURE ─────────────────────────────────
# ARCHITECTURE NOTE — i5-12500H hybrid scheduling:
# ┌─────────────────────────────────────────────────────────────────────┐
# │  6 Performance-cores (P)  │  each has HT -> 12 logical threads      │
# │  8 Efficiency-cores  (E)  │  no HT       ->  8 logical threads      │
# │  Total logical cores: 20                                            │
# └─────────────────────────────────────────────────────────────────────┘

# ── CPU THREAD ENVIRONMENT VARIABLES
# Read by orchestrator.py BEFORE any numpy/BLAS import. Overrides OS scheduler.
# Align with FASTEMBED_THREADS (P-core count).
OMP_NUM_THREADS=6
MKL_NUM_THREADS=6
OPENBLAS_NUM_THREADS=6

# Store models in project folder, not in system hidden folders
FASTEMBED_CACHE_PATH="/path/to/your/local_cache/models"

# ── DENSE CACHE EMBEDDER (Asymmetric Architecture)
# BAAI/bge-m3 handles Code, Math, Biology, and French natively.
# Used strictly for intent matching, decoupling cache from ColBERT.
CACHE_EMBEDDER_MODEL=BAAI/bge-m3
CACHE_EMBEDDING_DIM=1024
CACHE_SIMILARITY_THRESHOLD=0.85

# ── COLBERT LATE-INTERACTION EMBEDDER
# EMBEDDING_MAX_TOKENS: hard coordinate limit of Jina-ColBERT-v2's
# absolute position embedding table. Do NOT raise above 8192.
EMBEDDER_MODEL_NAME=jinaai/jina-colbert-v2
EMBEDDING_DIMENSION=128
EMBEDDING_MAX_TOKENS=8192
FASTEMBED_PROVIDER=CPUExecutionProvider
FASTEMBED_BATCH_SIZE=32
FASTEMBED_PARALLEL=0
FASTEMBED_THREADS=6


# ── 5. VECTOR & GRAPH DATABASES ──────────────────────────────────────────────

# ── VECTOR STORAGE LAYER (Qdrant via Docker)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_UPSERT_BATCH_SIZE=32

# ── ENTERPRISE GRAPH DATABASE (Neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here


# ── 6. RELATIONAL STATE & KV CACHE ───────────────────────────────────────────

# ── POSTGRESQL — SOURCE OF TRUTH
POSTGRES_URI=postgresql://omni:your_postgres_password_here@localhost:5432/omni_architect
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_POOL_MIN_SIZE=2
POSTGRES_POOL_MAX_SIZE=10

# ── REDIS — IN-MEMORY KV CACHE + CIRCUIT BREAKER STATE
REDIS_URI=redis://localhost:6379/0


# ── 7. MULTIMODAL & VLM PROCESSING ───────────────────────────────────────────

# VLM OCR Configuration
FORCE_VLM_OCR=false
VLM_OCR_DPI=150
VLM_OCR_BATCH_PAGES=1


# ── 8. SERVER & WORKSPACE CONFIGURATION ──────────────────────────────────────

# Storage Directories
DIR_INPUTS=OCR/inputs
DIR_OUTPUT=OCR/output
DIR_WORKSPACE=rag_workspace

# Server Binding
SERVER_HOST=localhost
SERVER_PORT=8000